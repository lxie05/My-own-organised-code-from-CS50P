calculation = input("What would you like me to calculate?")
x, y, z = calculation.split(" ")
x = float(x)
z = float(z)

match y:
    case "+":
        print (f"{x+z:.1f}")
    case "-":
        print (f"{x-z:.1f}")
    case "*":
        print (f"{x*z:.1f}")
    case "/":
        print (f"{x/z:.1f}")
